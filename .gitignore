# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a setup.py-based project, you may want to ignore Pipfile.lock.
#Lockfile should be ignored in library, but for application we can keep it
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to manage dependencies and lockfile to lock versions.
#   According to poetry's docs, poetry.lock should be committed.
#poetry.lock

# pdm
#   Similar to Poetry, PDM locking is committed.
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
system_env/

